# =============================================================================
# FSR Bidding Calculator — Environment Variable Template v2
# =============================================================================
# Copy this file to .env for local development.
# In Azure App Service, set these in Configuration → Application Settings.
# All secrets (marked *SECRET*) must be stored in Azure Key Vault and
# referenced here via Key Vault references, e.g.:
#   @Microsoft.KeyVault(SecretUri=https://fsr-kv.vault.azure.net/secrets/DB-PASSWORD/)
# =============================================================================

# ── Node environment ──────────────────────────────────────────────────────────
# 'production' on Azure App Service, 'development' locally
NODE_ENV=development

# ── Azure SQL Database ────────────────────────────────────────────────────────
DB_SERVER=fsr-sql-server.database.windows.net
DB_NAME=fsr-db
DB_USER=fsradmin
DB_PASSWORD=                            # *SECRET* — Key Vault reference in production

# ── Azure Active Directory (from AAD App Registration) ───────────────────────
# Application (client) ID — from Azure Portal > App Registrations > FSR Bidding Calculator
AZURE_CLIENT_ID=
# Directory (tenant) ID — from Azure Portal > App Registrations > FSR Bidding Calculator
AZURE_TENANT_ID=
# Client secret — *SECRET* 24-month expiry, rotate 60 days before expiry
AZURE_CLIENT_SECRET=                    # *SECRET* — Key Vault reference in production

# ── App Service ───────────────────────────────────────────────────────────────
# The front-end origin allowed by CORS (Static Web App URL or custom domain)
ALLOWED_ORIGIN=https://fsr-bidding-calculator.azurestaticapps.net
# Random 32-character string for session signing
SESSION_SECRET=                         # *SECRET* — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── SharePoint / Excel Sync (Azure Function) ──────────────────────────────────
# Full URL of the SharePoint site hosting the Excel pricing workbook
SHAREPOINT_SITE_URL=https://flixbus.sharepoint.com/sites/Facilities
# Drive item ID of the Excel file — preferred over file path (more stable)
# Find it: Graph Explorer > /sites/{siteId}/drive/root:/{filePath} > copy id field
SHAREPOINT_FILE_ID=
# Fallback if SHAREPOINT_FILE_ID is not set
SHAREPOINT_FILE_PATH=/Shared Documents/Pricing Tool/FSR_Pricing_Tool.xlsx

# ── Microsoft Teams (Q1 2027 — Approval routing Logic App) ───────────────────
# Incoming webhook URL for the Teams channel receiving approval notifications
# Create in Teams: channel > Connectors > Incoming Webhook > copy URL
TEAMS_WEBHOOK_URL=                      # Required for Q1 2027 Logic App approval routing

# ── Azure App Service port (do not change — Azure sets this automatically) ───
PORT=3000
